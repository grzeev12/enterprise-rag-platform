# Local development: shared by the Vercel app emulator and local worker.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/enterprise_ai_saas?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
REDIS_URL="redis://localhost:6379"
OBJECT_STORAGE_PROVIDER="azure-blob"
OBJECT_STORAGE_CONTAINER="enterprise-ai-saas"
AZURE_STORAGE_CONNECTION_STRING="UseDevelopmentStorage=true"
AZURE_STORAGE_CONTAINER_NAME="enterprise-ai-saas"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS="1536"
OPENAI_TIMEOUT_MS="30000"
OPENAI_MAX_RETRIES="2"
RAG_TOP_K="8"
RAG_SCORE_THRESHOLD="0.25"
RAG_MAX_CONTEXT_CHARS="12000"
RAG_MAX_OUTPUT_TOKENS="800"
INGESTION_WORKER_CONCURRENCY="3"
CRAWL_CHUNK_SIZE="1200"
CRAWL_CHUNK_OVERLAP="180"
EMBEDDING_JOB_MAX_CHUNKS="1000"
APPLICATIONINSIGHTS_CONNECTION_STRING=""
LOG_LEVEL="info"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_REQUESTS="60"
MAX_UPLOAD_BYTES="20971520"

# Low-cost MVP production app variables.
# These are used by the Next.js application layer only. Vercel enqueues jobs but does not run workers.
# DATABASE_URL="postgresql://<user>:<password>@<neon-host>/<database>?sslmode=require"
# AUTH_SECRET="<staging-auth-secret>"
# AUTH_URL="https://<staging-app>.vercel.app"
# NEXT_PUBLIC_APP_URL="https://<staging-app>.vercel.app"
# REDIS_URL="rediss://default:<upstash-password>@<upstash-host>:6379"
# OBJECT_STORAGE_PROVIDER="azure-blob"
# OBJECT_STORAGE_CONTAINER="enterprise-ai-saas-production"
# AZURE_STORAGE_CONNECTION_STRING="<staging-blob-connection-string>"
# AZURE_STORAGE_CONTAINER_NAME="enterprise-ai-saas-staging"
# R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# R2_ACCESS_KEY_ID="<r2-access-key>"
# R2_SECRET_ACCESS_KEY="<r2-secret-key>"
# OPENAI_API_KEY="<staging-openai-api-key>"
# OPENAI_CHAT_MODEL="gpt-4o-mini"
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Worker variables.
# MVP can run the worker on a small always-on VM/Fly.io/Render/Railway service.
# Azure Container Apps remains the future scaling target for the same Dockerfile.worker image.
# DATABASE_URL="postgresql://app_user:<password>@<prod-pg-server>.postgres.database.azure.com:5432/enterprise_ai_saas?schema=public&sslmode=require"
# REDIS_URL="rediss://:<access-key>@<prod-redis>.redis.cache.windows.net:6380"
# OBJECT_STORAGE_PROVIDER="azure-blob"
# OBJECT_STORAGE_CONTAINER="enterprise-ai-saas-production"
# AZURE_STORAGE_CONNECTION_STRING="<production-blob-connection-string>"
# AZURE_STORAGE_CONTAINER_NAME="enterprise-ai-saas-production"
# OPENAI_API_KEY="<production-openai-api-key>"
# OPENAI_CHAT_MODEL="gpt-4o-mini"
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
# INGESTION_WORKER_CONCURRENCY="3"
# CRAWL_CHUNK_SIZE="1200"
# CRAWL_CHUNK_OVERLAP="180"
# EMBEDDING_JOB_MAX_CHUNKS="1000"

# Future Azure migration equivalents.
# DATABASE_URL="postgresql://app_user:<password>@<pg-server>.postgres.database.azure.com:5432/enterprise_ai_saas?schema=public&sslmode=require"
# REDIS_URL="rediss://:<access-key>@<redis-name>.redis.cache.windows.net:6380"
